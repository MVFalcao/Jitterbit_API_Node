{
  "name": "Jitterbit_API_node",
  "version": "1.0.0",
  "description": "Node.js API de gerenciamento de pedidos.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --test testes/tests/api.test.js",
    "migrate": "knex migrate:latest",
    "rollback": "knex migrate:rollback",
    "make:migration": "knex migrate:make",
    "seed": "knex seed:run",
    "seed:admin": "knex seed:run --specific=admin_user.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
